#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$SCRIPT_DIR")"
AGENTS_DIR="$HOME/.claude/agents"

mkdir -p "$AGENTS_DIR"

echo "Installing deepresearch skills..."
echo ""

# Symlink each skill directory so Claude Code sees /dr:new, /dr:run, etc.
for skill in dr-new dr-run dr-status dr-review dr-resume dr-report dr-improve; do
    target="$SKILLS_DIR/$skill"
    rm -f "$target" 2>/dev/null || true
    ln -sf "$SCRIPT_DIR/$skill" "$target"
    echo "  ✓ /$(echo $skill | sed 's/-/:/')"
done

# Symlink agents
for agent in dr-researcher.md dr-evaluator.md; do
    rm -f "$AGENTS_DIR/$agent" 2>/dev/null || true
    ln -sf "$SCRIPT_DIR/agents/$agent" "$AGENTS_DIR/$agent"
    echo "  ✓ agent: $agent"
done

echo ""
echo "deepresearch installed. Open a new Claude Code session and type /dr: to see commands."
echo ""
echo "Available commands:"
echo "  /dr:new      — set up a new research project"
echo "  /dr:run      — execute research tasks autonomously"
echo "  /dr:status   — progress dashboard"
echo "  /dr:review   — validate data quality"
echo "  /dr:resume   — resume after crash or new session"
echo "  /dr:report   — synthesize final deliverable"
echo "  /dr:improve  — self-improvement loop for research quality"
